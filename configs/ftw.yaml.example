# Phase 2 -- FTW Mode, implement after Standard CV Mode is validated.
#
# Copy this file to ftw.yaml (gitignored) and set data.root to this machine's
# local dataset path.
mode: ftw

data:
  root: /path/to/Datasets/FTW
  split: val

prue:
  repo: https://github.com/fieldsoftheworld/ftw-prue
  checkpoint: null # path to PRUE checkpoint

backbone:
  name: ViT-L-14 # primary; georsclip-ViT-B-32 as secondary
  device: cuda

regions:
  min_area_px: 64
  pad_px_min: 16
  pad_frac: 0.1
  error_rate_threshold: 0.5

clustering:
  k_min: 2
  k_max: 8

naming:
  bootstrap_resamples: 500
  stability_threshold: 0.95
  top_k_concepts: 5

ftw_compare:
  intra_inter_divergence_threshold: 0.5 # cosine similarity

concept_bank: concept_banks/ftw_concepts.txt

output_dir: results/ftw
