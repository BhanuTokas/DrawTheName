# Phase 1 -- Standard CV Mode (Cityscapes), implement and validate first.
#
# Copy this file to standard_cv.yaml (gitignored) and set data.root to this
# machine's local dataset path.
mode: standard_cv

data:
  root: /path/to/Datasets/Cityscapes
  split: val
  limit: null # only process the first N images; null for the full split

segmentation_model:
  checkpoint: nvidia/segformer-b0-finetuned-cityscapes-1024-1024

backbone:
  name: ViT-L-14
  device: cuda

regions:
  min_area_px: 64
  pad_px_min: 16
  pad_frac: 0.1
  error_rate_threshold: 0.5
  subdivision_size: 192 # components larger than this^2 get split into a grid of this-sized sub-regions (192 + padding ~= CLIP's native 224x224 input, avoiding upscaling); null/omit to disable

clustering:
  k_min: 2
  k_max: 8

naming:
  bootstrap_resamples: 500
  cosine_threshold: 0.9 # per-resample cosine similarity needed to count as "agreeing"
  stability_threshold: 0.95
  residual_ratio_threshold: 0.1 # flag a direction in summary.md when ||deconfounded|| / ||raw|| falls below this -- concepts are ~arbitrary noise, not signal
  top_k_concepts: 10

concept_bank: concept_banks/general_concepts.txt

plots:
  max_points_per_class: 3000 # stratified subsample cap before UMAP fitting; null/omit for no cap

output_dir: results/standard_cv
